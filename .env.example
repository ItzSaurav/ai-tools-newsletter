GH_TOKEN=your_github_personal_access_token_with_repo_scope
GROQ_API_KEY=your_groq_api_key_from_console.groq.com
GMAIL_USER=your_sender_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_gmail_app_password
DRY_RUN=false

# Reddit OAuth (free, no credit card)
# 1. Go to https://www.reddit.com/prefs/apps
# 2. Click "create another app..." at the bottom
# 3. Name: "ai-tools-newsletter", Type: "script", redirect URI: "http://localhost"
# 4. After creating, "personal use script" = REDDIT_CLIENT_ID, "secret" = REDDIT_CLIENT_SECRET
# 5. Add both as GitHub Actions secrets (Settings → Secrets → Actions)
REDDIT_CLIENT_ID=your_reddit_app_client_id
REDDIT_CLIENT_SECRET=your_reddit_app_secret
